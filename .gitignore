# ==========================================
# 1. SEGURANÇA (O mais importante!)
# ==========================================
# Nunca suba arquivos de ambiente, senhas ou certificados
.env
.env.*
*.pem
*.key
*.cert

# ==========================================
# 2. BINÁRIOS E EXECUTÁVEIS DO GO
# ==========================================
# O Git serve para guardar código-fonte, não o programa compilado.
# Cada um compila o seu na sua própria máquina.
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
main

# ==========================================
# 3. TESTES E COBERTURA DO GO
# ==========================================
# Arquivos gerados quando rodamos testes de qualidade
coverage.out
coverage.html
profile.out

# ==========================================
# 4. AMBIENTES DE TRABALHO (Go Workspaces)
# ==========================================
go.work
go.work.sum

# ==========================================
# 5. ARQUIVOS DE IDES E EDITORES (VS Code, etc)
# ==========================================
# Configurações do seu editor de texto que são só suas
.vscode/
.idea/
*.swp
*.swo
*~

# ==========================================
# 6. ARQUIVOS DO SISTEMA OPERACIONAL
# ==========================================
# Lixo gerado automaticamente pelo Windows, Mac ou Linux
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db